# Copy this file to .env (repo root) and fill in real values.
# .env is gitignored — never commit it. Values must be raw or double-quoted
# (single quotes are NOT unwrapped; '#' outside quotes starts a comment).
# The backend loads .env automatically when started from the repo root.

# ---- Cloudinary (dashboard: Settings -> API Keys) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- PostgreSQL (local install, note the non-default port 5433) ----
DB_URL=jdbc:postgresql://localhost:5433/ticketing
DB_USERNAME=ticketing_app
DB_PASSWORD=

# ---- Ticket QR signing ----
# Any long random string, e.g. `openssl rand -base64 48`. Required — ticket issuing
# refuses to start without it. Changing it invalidates every existing QR code.
APP_TICKET_TOKEN_SECRET=

# ---- Redis / RabbitMQ (only set when different from localhost defaults) ----
# REDIS_HOST=localhost
# REDIS_PORT=6379
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest

# ---- Stripe (test mode only — see risk R-01) ----
# Secret key: Stripe dashboard -> Developers -> API keys (starts sk_test_)
# Webhook secret: printed by `stripe listen --forward-to localhost:8080/api/v1/webhooks/payments/stripe`
# Paid checkout stays switched off until the secret key is set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Email (Gmail SMTP) ----
# Emails go to the log by default. To send for real, set APP_EMAIL_TRANSPORT=smtp and fill in a
# Gmail address plus an app password (Google Account -> Security -> App passwords, not the login).
APP_EMAIL_TRANSPORT=log
# APP_EMAIL_FROM=your.name@gmail.com
# MAIL_USERNAME=your.name@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
