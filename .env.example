# Copy this file to .env (repo root) and fill in real values.
# .env is gitignored — never commit it. Values must be raw or double-quoted
# (single quotes are NOT unwrapped; '#' outside quotes starts a comment).
# The backend loads .env automatically when started from the repo root.

# ---- Cloudinary (dashboard: Settings -> API Keys) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- PostgreSQL (local install, note the non-default port 5433) ----
DB_URL=jdbc:postgresql://localhost:5433/ticketing
DB_USERNAME=ticketing_app
DB_PASSWORD=

# ---- Ticket QR signing ----
# Any long random string, e.g. `openssl rand -base64 48`. Required — ticket issuing
# refuses to start without it. Changing it invalidates every existing QR code.
APP_TICKET_TOKEN_SECRET=

# ---- Redis / RabbitMQ (only set when different from localhost defaults) ----
# REDIS_HOST=localhost
# REDIS_PORT=6379
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest

# ---- Filled in later phases ----
# STRIPE_SECRET_KEY=        (Phase 9 — Stripe test mode)
# STRIPE_WEBHOOK_SECRET=    (Phase 9)
# MAIL_USERNAME=            (Phase 10 — Gmail address)
# MAIL_PASSWORD=            (Phase 10 — Gmail app password)
